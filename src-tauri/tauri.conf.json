{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Time Remind",
  "version": "0.1.0",
  "identifier": "com.hpk.time-remind",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Time Remind",
        "width": 480,
        "height": 640,
        "minWidth": 400,
        "minHeight": 500,
        "center": true,
        "decorations": false,
        "resizable": true,
        "transparent": true,
        "visible": false
      },
      {
        "label": "notification",
        "title": "",
        "width": 360,
        "height": 224,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "focus": false,
        "skipTaskbar": true,
        "visible": false,
        "url": "notification.html",
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "Japanese",
          "Korean",
          "French",
          "German",
          "Vietnamese",
          "Thai",
          "Malay"
        ],
        "customLanguageFiles": {
          "Korean": "nsis/languages/Korean.nsh",
          "Thai": "nsis/languages/Thai.nsh",
          "Malay": "nsis/languages/Malay.nsh"
        },
        "displayLanguageSelector": true,
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
